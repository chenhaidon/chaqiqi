# ============================================
# 查企企 - 生产环境变量配置示例
# 复制本文件为 .env.production 并填入真实凭证
# ============================================

# 数据源开关:
#   mock = 使用内置示例数据
#   qcc  = 调用企查查真实接口
DATA_PROVIDER=qcc

# 企查查开放平台凭证
QCC_KEY=
QCC_SECRET_KEY=
QCC_BASE_URL=https://api.qichacha.com

# 查询缓存有效期(秒)
CACHE_TTL_SECONDS=86400

# SMTP 发信配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 线上访问域名，用于邮箱验证/重置密码链接
APP_BASE_URL=https://your-domain.com

# 生产调试开关，默认不要启用
ENABLE_QCC_DEBUG_API=false
