# ============================================
# 查企企 - 环境变量配置示例
# 复制本文件为 .env.local 并填入真实凭证
# ============================================

# 数据源开关:
#   mock = 使用内置浙江省示例数据(无需凭证,开箱即用)
#   qcc  = 调用企查查开放平台真实接口(需下方凭证)
DATA_PROVIDER=mock

# 企查查开放平台凭证 (https://open.qcc.com)
# AppKey
QCC_KEY=
# SecretKey (用于生成 Token 签名)
QCC_SECRET_KEY=
# 企查查接口基址(一般无需修改)
QCC_BASE_URL=https://api.qichacha.com

# 查询结果缓存有效期(秒),默认 24 小时
CACHE_TTL_SECONDS=86400
